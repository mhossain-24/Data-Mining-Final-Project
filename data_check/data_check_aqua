import os
import pandas as pd
import numpy as np
from PIL import Image
import matplotlib.pyplot as plt
from matplotlib.patches import Rectangle

img_dir = "/kaggle/input/datasets/musfirathossain/aqua-trash-dataset/Images"
ann_path = "/kaggle/input/datasets/musfirathossain/aqua-trash-dataset/annotations.csv"

print("Image folder exists:", os.path.exists(img_dir))
print("Annotation file exists:", os.path.exists(ann_path))

df = pd.read_csv(ann_path)

print("Shape:", df.shape)
print("Columns:", df.columns.tolist())
df.head()

print("Total annotations:", len(df))
print("\nClass counts:")
print(df["class_name"].value_counts())

image_files = [f for f in os.listdir(img_dir) if f.lower().endswith((".jpg", ".jpeg", ".png"))]
print("\nTotal images:", len(image_files))

image_sizes = {}

for img_name in image_files:
    img_path = os.path.join(img_dir, img_name)
    try:
        with Image.open(img_path) as img:
            w, h = img.size
            image_sizes[img_name] = (w, h)
    except Exception as e:
        print(f"Skipped {img_name}: {e}")

print("Readable images:", len(image_sizes))

df["img_w"] = df["image_name"].map(lambda x: image_sizes.get(x, (np.nan, np.nan))[0])
df["img_h"] = df["image_name"].map(lambda x: image_sizes.get(x, (np.nan, np.nan))[1])

# Remove rows where image size could not be found
df = df.dropna(subset=["img_w", "img_h"]).copy()

# Bounding box calculations
df["bbox_w"] = df["x_max"] - df["x_min"]
df["bbox_h"] = df["y_max"] - df["y_min"]

df["x_center"] = ((df["x_min"] + df["x_max"]) / 2) / df["img_w"]
df["y_center"] = ((df["y_min"] + df["y_max"]) / 2) / df["img_h"]

df["bbox_w_norm"] = df["bbox_w"] / df["img_w"]
df["bbox_h_norm"] = df["bbox_h"] / df["img_h"]

df.head()

# Optional sanity check
print("Final usable annotations:", len(df))
print("\nClasses:")
print(df["class_name"].value_counts())

import matplotlib.pyplot as plt
from matplotlib.patches import Rectangle
import numpy as np

# Class counts
class_counts = df["class_name"].value_counts().sort_values(ascending=False)

# Bright colors for each class
class_color_map = {
    "plastic": "#1f77b4",   # blue
    "metal":   "#17becf",   # cyan
    "paper":   "#e377c2",   # pink
    "glass":   "#2ca02c"    # green
}

# fallback colors if any class name differs
bar_colors = [class_color_map.get(cls, "#9467bd") for cls in class_counts.index]

fig, axes = plt.subplots(2, 2, figsize=(14, 12))

#Top-left: Class Frequency
bars = axes[0, 0].bar(class_counts.index, class_counts.values, color=bar_colors)
#axes[0, 0].set_title("Class Frequency", fontsize=14)
axes[0, 0].set_ylabel("Instances", fontsize=12)

for i, v in enumerate(class_counts.values):
    axes[0, 0].text(i, v + 2, str(v), ha="center", fontsize=10, fontweight="bold")

#Top-right: Bounding-Box Overlay
overlay_df = df.sample(min(len(df), 300), random_state=42)

for _, row in overlay_df.iterrows():
    x = row["x_center"] - row["bbox_w_norm"] / 2
    y = row["y_center"] - row["bbox_h_norm"] / 2
    cls = row["class_name"]
    color = class_color_map.get(cls, "#7f7f7f")

    rect = Rectangle(
        (x, y),
        row["bbox_w_norm"],
        row["bbox_h_norm"],
        fill=False,
        edgecolor=color,
        alpha=0.12,
        linewidth=1
    )
    axes[0, 1].add_patch(rect)

axes[0, 1].set_xlim(0, 1)
axes[0, 1].set_ylim(1, 0)
axes[0, 1].set_aspect("equal")
#axes[0, 1].set_title("Bounding-Box Overlay Patterns", fontsize=14)
axes[0, 1].axis("off")

#Bottom-left: Object-Center Distribution
h1 = axes[1, 0].hist2d(
    df["x_center"],
    df["y_center"],
    bins=50,
    range=[[0, 1], [0, 1]],
    cmap="Blues"
)
#axes[1, 0].set_title("Object-Center Distribution", fontsize=14)
axes[1, 0].set_xlabel("x", fontsize=12)
axes[1, 0].set_ylabel("y", fontsize=12)

#Bottom-right: Width-Height Distribution
h2 = axes[1, 1].hist2d(
    df["bbox_w_norm"],
    df["bbox_h_norm"],
    bins=50,
    range=[[0, 1], [0, 1]],
    cmap="Purples"
)
